# AI 错题分析功能配置
# 复制本文件为 .env.local 后再修改

# 必填：模型服务 API Key
EXPO_PUBLIC_AI_API_KEY=your_api_key_here

# 可选：openai | deepseek | claude
# 不填时当前代码默认走 openai
EXPO_PUBLIC_AI_PROVIDER=openai

# 可选：通用代理 base URL
# Claude on Web 通常需要配置；DeepSeek / OpenAI 走自建代理时也可填写
# EXPO_PUBLIC_DEEPSEEK_PROXY_URL=http://localhost:9876
